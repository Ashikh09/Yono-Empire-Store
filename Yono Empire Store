<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yono Empire Store</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <h1>YONO EMPIRE STORE</h1>
    <p>Trusted Yono Games Collection</p>
</header>

<div class="container">

    <div class="card">
        <img src="logo1.png" alt="App Logo">
        <h2>Yono VIP</h2>
        <p>Bonus ₹8 - ₹33</p>
        <a href="#">Download APK</a>
    </div>

    <div class="card">
        <img src="logo2.png" alt="App Logo">
        <h2>Bingo 101</h2>
        <p>New User Bonus Available</p>
        <a href="#">Download APK</a>
    </div>

</div>

<footer>
    <p>© 2026 Yono Empire Store. All Rights Reserved.</p>
</footer>

</body>
</html>
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#f5f5f5;
}

header{
    background:#0d6efd;
    color:white;
    text-align:center;
    padding:25px;
}

.container{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:20px;
    padding:20px;
}

.card{
    background:white;
    width:300px;
    padding:20px;
    border-radius:12px;
    text-align:center;
    box-shadow:0 4px 10px rgba(0,0,0,.1);
}

.card img{
    width:80px;
    height:80px;
}

.card a{
    display:inline-block;
    margin-top:10px;
    padding:10px 20px;
    background:#0d6efd;
    color:white;
    text-decoration:none;
    border-radius:5px;
}

footer{
    text-align:center;
    padding:15px;
    background:#222;
    color:white;
}
